# Recipio Configuration
# This file is automatically loaded by the backend server

# Backend CORS Configuration
# Comma-separated list of allowed origins
# Examples:
# ALLOWED_ORIGINS=http://192.168.1.170:4002
# ALLOWED_ORIGINS=https://yourdomain.com,http://192.168.1.170:4002
ALLOWED_ORIGINS=http://192.168.1.170:4002

# Frontend API Configuration
# Base URL for API calls from the frontend
# Examples:
# VITE_API_BASE=http://localhost:4002
# VITE_API_BASE=http://192.168.1.170:4002
# VITE_API_BASE=https://yourdomain.com
VITE_API_BASE=http://192.168.1.170:4002