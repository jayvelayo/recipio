# Recipio Configuration
# Copy to .env and set values as needed.

# PORT=4002   # override the server listen port

# GROQ_API_KEY=

# Google OAuth (leave unset to disable Google sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:4002/auth/google/callback

# Email verification via Resend (https://resend.com)
# Leave unset to auto-verify accounts in local development.
# RESEND_API_KEY=
# EMAIL_FROM=Recipio <noreply@yourdomain.com>  # must be a verified Resend sender domain

# Public URL of the app — used to build email links and added to CORS allowed origins.
# Set this when accessing the server from a non-localhost address (e.g. a LAN IP or domain).
# APP_URL=http://192.168.1.170:4002
